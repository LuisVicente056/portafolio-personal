@page "/sobremi"
@using Microsoft.AspNetCore.Components.Forms

<div class="container py-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h2 class="display-4 fw-bold">Sobre Mí</h2>
        <div class="bg-primary mx-auto mb-4" style="width:80px;height:4px;border-radius:2px;"></div>

        <p class="text-muted fs-5">
            Próximo Licenciado en Informática y desarrollador Full Stack apasionado por crear soluciones modernas e innovadoras.
        </p>
    </div>

    <div class="row g-5 align-items-start">

        <!-- PERFIL -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="bg-primary p-4 text-center text-white">

                    <div class="mb-3">
                        @if (imageDataUrl == null)
                        {
                            <i class="bi bi-person-workspace d-block" style="font-size:5rem;"></i>
                        }
                        else
                        {
                            <img src="@imageDataUrl"
                                 class="rounded-circle border border-4 border-white shadow"
                                 style="width:150px;height:150px;object-fit:cover;" />
                        }
                    </div>

                    <label class="btn btn-light btn-sm rounded-pill mb-2">
                        Cambiar Foto
                        <InputFile OnChange="HandleFileSelected"
                                   class="d-none"
                                   accept="image/*" />
                    </label>

                    <h3 class="mt-2">Luis Manuel Vicente Ramos</h3>

                    <p class="mb-0 opacity-75">
                        SFM, República Dominicana
                    </p>

                </div>

                <div class="card-body p-4">

                    <ul class="list-unstyled mb-0">

                        <li class="mb-3">
                            <i class="bi bi-envelope-fill text-primary me-2"></i>
                            tu-correo@email.com
                        </li>

                        <li class="mb-3">
                            <i class="bi bi-geo-alt-fill text-primary me-2"></i>
                            San Francisco de Macorís
                        </li>

                        <li>
                            <i class="bi bi-github text-primary me-2"></i>
                            github.com/tu-usuario
                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <!-- INFORMACION -->
        <div class="col-lg-8">

            <div class="card border-0 shadow-lg rounded-4 p-4 h-100">

                <h4 class="text-primary fw-bold mb-3">
                    <i class="bi bi-quote me-2"></i>
                    Filosofía Profesional
                </h4>

                <p class="text-secondary fs-6 mb-4">
                    Próximo <strong>Licenciado en Informática</strong>
                    y desarrollador <strong>Full Stack</strong>
                    especializado en tecnologías
                    <strong>.NET</strong>,
                    <strong>Blazor</strong> y
                    <strong>SQL Server</strong>.
                    Apasionado por diseñar soluciones modernas y escalables que optimicen procesos académicos y empresariales mediante desarrollo web, bases de datos y arquitectura de software eficiente.
                </p>

                <div class="row g-3">

                    <!-- ENFOQUE TÉCNICO -->
                    <div class="col-md-5">
                        <div class="p-3 border rounded-4 shadow-sm bg-light h-100">
                            <h6 class="text-uppercase fw-bold text-muted mb-3">Enfoque Técnico</h6>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-primary">Blazor</span>
                                <span class="badge bg-primary">C#</span>
                                <span class="badge bg-primary">SQL Server</span>
                                <span class="badge bg-primary">.NET</span>
                                <span class="badge bg-primary">Bootstrap</span>
                                <span class="badge bg-primary">HTML / CSS</span>
                            </div>
                        </div>
                    </div>

                    <!-- CURSOS -->
                    <div class="col-md-7">

                        <div class="p-4 border-0 rounded-4 shadow-sm bg-white h-100 modern-course-card">

                            <div class="d-flex align-items-center mb-3">

                                <div class="icon-circle me-3">
                                    <i class="bi bi-mortarboard-fill"></i>
                                </div>

                                <div>

                                    <h5 class="fw-bold mb-0">
                                        Cursos y Tecnologías
                                    </h5>

