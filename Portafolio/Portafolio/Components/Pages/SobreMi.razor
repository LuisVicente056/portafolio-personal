                                        <div class="d-flex align-items-center">

                                            <i class="bi bi-file-earmark-excel-fill me-3 fs-4 text-success"></i>

                                            <div>

                                                <div class="fw-semibold text-dark">
                                                    Microsoft Excel Avanzado
                                                </div>

                                                <small class="text-secondary">
                                                    Fórmulas, tablas dinámicas y análisis
                                                </small>

                                            </div>

                                        </div>

                                        <i class="bi bi-box-arrow-up-right text-primary"></i>

                                    </div>

                                </a>

                                <!-- CIENCIA DE DATOS -->
                                <a href="/certificados/ciencia_datos_intermedio.pdf"
                                   target="_blank"
                                   class="course-item text-decoration-none">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <div class="d-flex align-items-center">

                                            <i class="bi bi-bar-chart-line-fill me-3 fs-4 text-primary"></i>

                                            <div>

                                                <div class="fw-semibold text-dark">
                                                    Ciencia de Datos - Nivel Intermedio
                                                </div>

                                                <small class="text-secondary">
                                                    Análisis de datos, lógica y herramientas tecnológicas
                                                </small>

                                            </div>

                                        </div>

                                        <i class="bi bi-box-arrow-up-right text-primary"></i>

