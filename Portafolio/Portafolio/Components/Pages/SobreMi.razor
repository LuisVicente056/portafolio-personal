                                    </div>

                                </a>

                                <!-- ITIL -->
                                <a href="/certificados/itil.pdf"
                                   target="_blank"
                                   class="course-item text-decoration-none">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <div class="d-flex align-items-center">

                                            <i class="bi bi-shield-check me-3 fs-4 text-info"></i>

                                            <div>

                                                <div class="fw-semibold text-dark">
                                                    ITIL & Gestión IT
                                                </div>

                                                <small class="text-secondary">
                                                    Buenas prácticas y servicios TI
                                                </small>

                                            </div>

                                        </div>

                                        <i class="bi bi-box-arrow-up-right text-primary"></i>

                                    </div>

                                </a>

                            </div>

                            <div class="mt-4 pt-3 border-top">

                                <small class="text-secondary d-block mb-2">
                                    Plataformas oficiales de aprendizaje
                                </small>

                                <div class="d-flex flex-wrap gap-2">

                                    <a href="https://learn.microsoft.com/"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        Microsoft Learn
                                    </a>

                                    <a href="https://www.sap.com/"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        SAP
                                    </a>

                                    <a href="https://www.axelos.com/"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        AXELOS ITIL
                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <div class="mt-4">

                    <a href="/contacto"
                       class="btn custom-contact-btn btn-lg px-5 py-3 rounded-pill fw-semibold">

                        <i class="bi bi-chat-dots-fill me-2"></i>

                        Contactar para proyectos

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    .modern-course-card {
        transition: transform .35s ease, box-shadow .35s ease;
    }

        .modern-course-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(37,99,235,.12) !important;
        }

    .icon-circle {
        width: 55px;
        height: 55px;
        border-radius: 18px;
        background: #eff6ff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    .course-item {
        padding: 1rem;
        border-radius: 18px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        transition: all .3s ease;
    }

        .course-item:hover {
            background: #2563eb;
            transform: translateY(-3px);
            border-color: #2563eb;
            box-shadow: 0 12px 25px rgba(37,99,235,.18);
        }

            .course-item:hover .text-dark,
            .course-item:hover .text-secondary,
            .course-item:hover i {
                color: white !important;
            }

    .custom-contact-btn {
        background: white;
        color: #2563eb;
        border: 2px solid #dbeafe;
        box-shadow: 0 10px 25px rgba(37,99,235,.08);
        transition: all .35s ease;
    }

        .custom-contact-btn:hover {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(37,99,235,.25);
        }

</style>

@code
{
    private string? imageDataUrl;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var imageFile = e.File;

        if (imageFile != null)
        {
            var format = "image/png";

            var resizedImage = await imageFile.RequestImageFileAsync(
                format,
                300,
                300);

            var buffer = new byte[(int)resizedImage.Size];

            await resizedImage.OpenReadStream().ReadAsync(buffer);

            imageDataUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
        }
    }
}
