@page "/contacto"
@rendermode InteractiveServer

<div class="container py-5">
    <div class="row">
        <!-- Columna de Redes Sociales y Contacto Directo -->
        <div class="col-lg-4 mb-4">
            <div class="card p-4 h-100 shadow-sm">
                <h3 class="mb-4">Contacto</h3>
                <p class="text-muted mb-4">¿Tienes alguna pregunta o propuesta? Escríbeme por cualquiera de estos medios.</p>

                <div class="d-flex flex-column gap-3">
                    <a href="mailto:tuemail@ejemplo.com" class="btn btn-outline-primary d-flex align-items-center">
                        <i class="bi bi-envelope-fill me-2"></i> tuemail@ejemplo.com
                    </a>
                    <a href="https://linkedin.com/in/tuperfil" target="_blank" class="btn btn-outline-primary d-flex align-items-center">
                        <i class="bi bi-linkedin me-2"></i> LinkedIn
                    </a>
                    <a href="https://github.com/tuusuario" target="_blank" class="btn btn-outline-dark d-flex align-items-center">
                        <i class="bi bi-github me-2"></i> GitHub
                    </a>
                    <a href="https://wa.me/1234567890" target="_blank" class="btn btn-outline-success d-flex align-items-center">
                        <i class="bi bi-whatsapp me-2"></i> WhatsApp
                    </a>
                </div>
            </div>
        </div>

        <!-- Columna del Formulario -->
        <div class="col-lg-8">
            <div class="card p-4 shadow-sm">
                <h3 class="mb-4">Envíame un mensaje</h3>
                <EditForm Model="@modelo" OnValidSubmit="EnviarMensaje">
                    <div class="mb-3">
                        <label class="form-label">Nombre Completo</label>
                        <InputText @bind-Value="modelo.Nombre" class="form-control" placeholder="Tu nombre" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Correo Electrónico</label>
                        <InputText @bind-Value="modelo.Email" type="email" class="form-control" placeholder="correo@ejemplo.com" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mensaje</label>
                        <InputTextArea @bind-Value="modelo.Mensaje" class="form-control" rows="5" placeholder="Cuéntame sobre tu proyecto..." />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-send-fill me-2"></i> Enviar Mensaje
                    </button>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private ContactoForm modelo = new();

    private void EnviarMensaje()
    {
        // Aquí puedes conectar con tu base de datos mediante Entity Framework
        Console.WriteLine($"Mensaje de {modelo.Nombre} enviado.");
    }

    public class ContactoForm
    {
        public string Nombre { get; set; } = "";
        public string Email { get; set; } = "";
        public string Mensaje { get; set; } = "";
    }
}
