@page "/habilidades"

<div class="container py-5">
    <!-- Título Principal -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">Habilidades Técnicas</h2>
        <p class="text-muted">Un resumen de las tecnologías y herramientas que domino.</p>
    </div>

    <div class="row g-4">

        <!-- Categoría 1: Desarrollo -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 p-4">
                <h4 class="text-primary mb-3"><i class="bi bi-code-slash"></i> Desarrollo</h4>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> C# / .NET 10</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Blazor (Server/WASM)</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Entity Framework Core</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> JavaScript / HTML5 / CSS3</li>
                </ul>
            </div>
        </div>

        <!-- Categoría 2: Bases de Datos -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 p-4">
                <h4 class="text-primary mb-3"><i class="bi bi-database-fill"></i> Bases de Datos</h4>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> SQL Server</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Diseño de Modelo Entidad-Relación</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Optimización de Consultas</li>
                </ul>
            </div>
        </div>

        <!-- Categoría 3: Herramientas y Otros -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 p-4">
                <h4 class="text-primary mb-3"><i class="bi bi-tools"></i> Herramientas</h4>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Git / GitHub</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Visual Studio 2022</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> ITIL / Gestión de IT</li>
                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Business Intelligence (BI)</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Barra de progreso visual (Opcional pero muy profesional) -->
    <div class="mt-5 p-4 card border-0 shadow-sm">
        <h5 class="mb-4">Nivel de dominio principal</h5>

        <div class="mb-3">
            <div class="d-flex justify-content-between"><span>C# / Blazor</span><span>90%</span></div>
            <div class="progress" style="height: 10px;">
                <div class="progress-bar bg-primary" style="width: 90%"></div>
            </div>
        </div>

        <div class="mb-3">
            <div class="d-flex justify-content-between"><span>SQL Server</span><span>80%</span></div>
            <div class="progress" style="height: 10px;">
                <div class="progress-bar bg-primary" style="width: 80%"></div>
            </div>
        </div>
    </div>
</div>

@code {

    // Aquí puedes agregar lógica si quieres mostrar años de experiencia
    // de forma dinámica, pero para habilidades, el HTML estático es muy efectivo.
}