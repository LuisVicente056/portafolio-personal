@page "/proyectos"
@rendermode InteractiveServer

<div class="container py-5">

    <!-- HEADER -->
    <div class="text-center mb-5">

        <h1 class="fw-bold display-5">
            Mis Proyectos
        </h1>

        <p class="text-secondary fs-5">
            Desarrollo de software enfocado en soluciones modernas,
            eficientes y escalables.
        </p>

    </div>

    <!-- PROYECTOS -->
    <div class="row g-4">

        @for (int i = 0; i < listaProyectos.Count; i++)
        {
            var proyecto = listaProyectos[i];

            <div class="col-md-6 col-lg-4">

                <div class="card h-100 border-0 shadow-sm project-card transition-effect">

                    <!-- IMAGEN -->
                    <img src="@proyecto.ImagenUrl"
                         class="card-img-top"
                         alt="@proyecto.Titulo"
                         style="height: 220px; object-fit: cover;">

                    <div class="card-body d-flex flex-column p-4">

                        <!-- TITULO -->
                        <div class="d-flex justify-content-between align-items-start mb-2">

                            <h5 class="card-title fw-bold mb-0">
                                @proyecto.Titulo
                            </h5>

                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                                v@proyecto.VersionActual
                            </span>

                        </div>

                        <!-- DESCRIPCIÓN -->
                        <p class="card-text text-secondary flex-grow-1 mt-3">
                            @proyecto.Descripcion
                        </p>

                        <!-- TECNOLOGÍAS -->
                        <div class="d-flex flex-wrap gap-2 mb-4">

                            @foreach (var tech in proyecto.Tecnologias)
                            {
                                <span class="badge-tech">
                                    @tech
                                </span>
                            }

                        </div>

                        <!-- ACORDEÓN -->
                        <div class="accordion accordion-flush mb-4 border rounded-4 overflow-hidden"
                             id="accordion-@i">

                            <div class="accordion-item border-0">

                                <h2 class="accordion-header">

                                    <button class="accordion-button collapsed fw-semibold py-3"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#collapse-@i">

                                        <i class="bi bi-layers-fill me-2 text-primary"></i>

                                        Versiones disponibles

                                    </button>

                                </h2>

                                <div id="collapse-@i"
                                     class="accordion-collapse collapse"
                                     data-bs-parent="#accordion-@i">

                                    <div class="accordion-body p-0">

                                        <div class="list-group list-group-flush">

                                            @foreach (var v in proyecto.Versiones)
                                            {
                                                <a href="@v.Link"
                                                   download
                                                   rel="noopener noreferrer"
                                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">

                                                    <div>

                                                        <div class="fw-semibold">
                                                            Versión @v.Nombre
                                                        </div>

                                                        <small class="text-secondary">
                                                            Descargar archivo ZIP
                                                        </small>

                                                    </div>

                                                    <i class="bi bi-download text-primary fs-5"></i>

                                                </a>
                                            }

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- BOTONES -->
                        <div class="d-grid gap-2 mt-auto">

                            <!-- DESCARGAR -->
                            <a href="@proyecto.LinkDescarga"
                               download
                               rel="noopener noreferrer"
                               class="btn btn-primary py-2 rounded-3">

                                <i class="bi bi-download me-2"></i>

                                Descargar Proyecto

                            </a>

                            <!-- GITHUB -->
                            <a href="@proyecto.GitHubUrl"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="btn btn-outline-dark py-2 rounded-3">

                                <i class="bi bi-github me-2"></i>

                                Ver Código Fuente

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<style>

    .transition-effect {
        transition: transform .35s ease, box-shadow .35s ease;
    }

        .transition-effect:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(15,23,42,.12) !important;
        }

    .project-card {
        border-radius: 24px;
        overflow: hidden;
    }

        .project-card img {
            transition: transform .4s ease;
        }

        .project-card:hover img {
            transform: scale(1.03);
        }

    .badge-tech {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #334155;
        padding: .5rem .9rem;
        border-radius: 999px;
        font-size: .82rem;
        font-weight: 500;
        transition: all .25s ease;
    }

        .badge-tech:hover {
            background: var(--bs-primary);
            color: white;
            border-color: var(--bs-primary);
            transform: translateY(-2px);
        }

    .accordion-button {
        background: white !important;
        box-shadow: none !important;
    }

        .accordion-button:not(.collapsed) {
            color: var(--bs-primary);
        }

        .accordion-button:focus {
            box-shadow: none;
        }

</style>

@code {

    private List<Proyecto> listaProyectos = new();

    protected override void OnInitialized()
    {
        listaProyectos.Add(new Proyecto
        {
            Titulo = "Sistema de Inscripción",

            Descripcion =
            "Aplicación desarrollada en C# y SQL Server para la gestión académica de estudiantes y profesores.",

            ImagenUrl =
            "https://images.unsplash.com/photo-1555949963-aa9fe0c970b8?q=80&w=1200",

            VersionActual = "1.5",

            GitHubUrl = "https://github.com/tuusuario/sistema-inscripcion",

            Tecnologias = new()
            {
                "C#",
                ".NET",
                "SQL Server",
                "Windows Forms"
            },

            Versiones = new List<DetalleVersion>
            {
                new()
                {
                    Nombre = "1.0",
                    Link = "/descargas/inscripcion_v1.0.zip"
                },

                new()
                {
                    Nombre = "1.2",
                    Link = "/descargas/inscripcion_v1.2.zip"
                },

                new()
                {
                    Nombre = "1.5",
                    Link = "/descargas/inscripcion_v1.5.zip"
                }
            }
        });

        listaProyectos.Add(new Proyecto
        {
            Titulo = "Payroll Zapatos Criollos",

            Descripcion =
            "Sistema de nómina para cálculo automático de deducciones y pagos empresariales.",

            ImagenUrl =
            "https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?q=80&w=1200",

            VersionActual = "1.0",

            GitHubUrl = "https://github.com/tuusuario/payroll-system",

            Tecnologias = new()
            {
                "C#",
                "Entity Framework",
                "SQL Server",
                "Bootstrap"
            },

            Versiones = new List<DetalleVersion>
            {
                new()
                {
                    Nombre = "Beta",
                    Link = "/descargas/payroll_beta.zip"
                },

                new()
                {
                    Nombre = "1.0",
                    Link = "/descargas/payroll_v1.0.zip"
                }
            }
        });
    }

    // MODELO PROYECTO
    public class Proyecto
    {
        public string Titulo { get; set; } = "";

        public string Descripcion { get; set; } = "";

        public string ImagenUrl { get; set; } = "";

        public string VersionActual { get; set; } = "";

        public string GitHubUrl { get; set; } = "";

        public List<string> Tecnologias { get; set; } = new();

        public List<DetalleVersion> Versiones { get; set; } = new();

        public string LinkDescarga =>
            Versiones.Count > 0
            ? Versiones.Last().Link
            : "#";
    }

    // VERSIONES
    public class DetalleVersion
    {
        public string Nombre { get; set; } = "";

        public string Link { get; set; } = "";
    }
}