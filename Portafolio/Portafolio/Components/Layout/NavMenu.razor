<script>
    function alternarTemaBootstrap() {
        // Buscamos el contenedor que tiene el atributo de Bootstrap
        const contenedor = document.querySelector('[data-bs-theme]');
        const icono = document.getElementById('icono-tema');

        // Leemos el tema actual
        let tema = contenedor.getAttribute('data-bs-theme');

        if (tema === 'light') {
            contenedor.setAttribute('data-bs-theme', 'dark');
            icono.textContent = '☀️';
        } else {
            contenedor.setAttribute('data-bs-theme', 'light');
            icono.textContent = '🌙';
        }
    }
</script>